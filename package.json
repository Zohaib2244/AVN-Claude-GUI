{
  "name": "avn-claude-gui",
  "displayName": "AVN Chat",
  "description": "Standalone sidebar chat powered by the Claude Code CLI",
  "version": "0.2.1",
  "publisher": "personal",
  "private": true,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claude-sidebar",
          "title": "AVN Chat",
          "icon": "media/claude-icon.svg"
        }
      ]
    },
    "views": {
      "claude-sidebar": [
        {
          "type": "webview",
          "id": "claude.chatView",
          "name": "Chat",
          "icon": "media/claude-icon.svg",
          "contextualTitle": "AVN Chat"
        }
      ]
    },
    "commands": [
      {
        "command": "claude.openChat",
        "title": "Claude: Open Chat"
      },
      {
        "command": "claude.toggleYolo",
        "title": "Claude: Toggle YOLO Mode"
      },
      {
        "command": "claude.showUsage",
        "title": "Claude: Show Usage"
      },
      {
        "command": "claude.switchModel",
        "title": "Claude: Switch Model"
      },
      {
        "command": "claude.switchBudget",
        "title": "Claude: Switch Thinking Budget"
      },
      {
        "command": "claude.restartProcess",
        "title": "Claude: Restart CLI Process"
      },
      {
        "command": "claude.indexProject",
        "title": "Claude: Index Project"
      },
      {
        "command": "avn.keepFileChanges",
        "title": "AVN: Keep AI changes to this file"
      },
      {
        "command": "avn.revertFileChanges",
        "title": "AVN: Revert AI changes to this file"
      },
      {
        "command": "avn.keepHunk",
        "title": "AVN: Keep this AI change"
      },
      {
        "command": "avn.revertHunk",
        "title": "AVN: Undo this AI change"
      },
      {
        "command": "avn.nextHunk",
        "title": "AVN: Next AI change"
      },
      {
        "command": "avn.prevHunk",
        "title": "AVN: Previous AI change"
      }
    ],
    "keybindings": [
      { "command": "avn.nextHunk", "key": "alt+down", "mac": "alt+down", "when": "editorTextFocus" },
      { "command": "avn.prevHunk", "key": "alt+up",   "mac": "alt+up",   "when": "editorTextFocus" }
    ],
    "configuration": {
      "title": "AVN Chat",
      "properties": {
        "claude.models": {
          "type": "array",
          "default": [
            "claude-opus-4-7",
            "claude-sonnet-4-6",
            "claude-haiku-4-5",
            "claude-opus-4-5",
            "claude-sonnet-4-5"
          ],
          "description": "Available Claude models"
        },
        "claude.defaultModel": {
          "type": "string",
          "default": "claude-sonnet-4-6",
          "description": "Default model to use"
        },
        "claude.maxFolderContextKb": {
          "type": "number",
          "default": 500,
          "description": "Maximum KB of folder content to include in context"
        },
        "claude.completionDebounceMs": {
          "type": "number",
          "default": 500,
          "description": "Debounce delay in ms for inline completions"
        },
        "claude.dailyTokenLimit": {
          "type": "number",
          "default": 0,
          "description": "Daily token limit (0 = no limit)"
        },
        "claude.thinkingModels": {
          "type": "array",
          "default": [
            "claude-opus-4-7",
            "claude-opus-4-5"
          ],
          "description": "Models that support extended thinking"
        },
        "claude.openCodeModels": {
          "type": "array",
          "default": [],
          "description": "Available OpenCode models (format: provider/model). Add from the model picker in AVN Chat."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
